# ============================================================
# ExamCPNS API – Environment variables (Dokploy panel)
# Salin key-value ini ke panel Environment di Dokploy.
# ============================================================

NODE_ENV=production
PORT=3001

# PostgreSQL (external / Dokploy managed)
DATABASE_URL=postgresql://user:password@host:5432/exampns_api?schema=public

# Auth
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
BETTER_AUTH_URL=https://api.example.com
FRONTEND_URL=https://app.example.com
PUBLIC_API_URL=https://api.example.com

# Email
EMAIL_PROVIDER=smtp
EMAIL_FROM=ExamCPNS <noreply@example.com>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Startup: migrate deploy aktif default; db push opsional (fresh DB tanpa migration history)
RUN_DB_PUSH_ON_STARTUP=false
RUN_MIGRATE_ON_STARTUP=true
BOOTSTRAP_ON_STARTUP=true

# Super admin pertama (opsional, dibuat saat bootstrap)
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=change-me-strong-password

# n8n / AI recommendation (opsional)
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
AI_RECOMMENDATION_TIMEOUT_MS=8000

# PDF import via n8n (opsional)
PDF_IMPORT_WEBHOOK_URL=
PDF_IMPORT_CALLBACK_SECRET=

# Payment gateway (opsional)
PAYMENT_GATEWAY_PROVIDER=manual
PAYMENT_GATEWAY_BASE_URL=https://payment-gateway.example
PAYMENT_WEBHOOK_SECRET=
